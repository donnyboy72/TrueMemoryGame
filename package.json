{
  "name": "matching-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:sim": "tsc -p tsconfig.sim.json",
    "simulate": "node dist-sim/simulation/compare_simulations.js",
    "simulate:math": "set SIM_MODE=math && node dist-sim/simulation/compare_simulations.js",
    "simulate:llm": "set SIM_MODE=llm && node dist-sim/simulation/compare_simulations.js",
    "simulate:both": "set SIM_MODE=both && node dist-sim/simulation/compare_simulations.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "uuid": "^13.0.0",
    "vite": "^7.2.4"
  }
}
